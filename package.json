{
  "name": "apple-reminders-mcp",
  "version": "1.0.0",
  "description": "MCP server providing Apple Reminders access via SSE transport",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build:ts": "tsc",
    "build:swift": "cd src/swift && chmod +x build.sh && ./build.sh",
    "build": "npm run build:ts && npm run build:swift",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "clean": "rm -rf dist && rm -f src/swift/bin/reminders-cli"
  },
  "keywords": [
    "mcp",
    "apple",
    "reminders",
    "eventkit",
    "sse"
  ],
  "author": "meimakes",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
